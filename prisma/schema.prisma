generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model conversation {
  id          String     @id @default(cuid())
  title       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      String
  workspaceId String?
  modelId     String     @default("gemini-1.5-flash")
  isPinned    Boolean    @default(false)
  isArchived  Boolean    @default(false)
  user        user       @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Conversation_userId_fkey")
  workspace   workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "Conversation_workspaceId_fkey")
  message     message[]

  @@index([userId], map: "Conversation_userId_idx")
  @@index([workspaceId], map: "Conversation_workspaceId_idx")
}

model document {
  id              String         @id @default(cuid())
  name            String
  url             String
  key             String
  size            Int
  type            String
  status          String         @default("PENDING")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  knowledgeBaseId String?
  knowledgebase   knowledgebase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade, map: "Document_knowledgeBaseId_fkey")
  user            user           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Document_userId_fkey")

  @@index([knowledgeBaseId], map: "Document_knowledgeBaseId_idx")
  @@index([userId], map: "Document_userId_idx")
}

model knowledgebase {
  id          String     @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspaceId String     @unique(map: "KnowledgeBase_workspaceId_key")
  document    document[]
  workspace   workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "KnowledgeBase_workspaceId_fkey")
}

model message {
  id             String       @id @default(cuid())
  role           String
  content        String       @db.LongText
  tokens         Int?
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "Message_conversationId_fkey")

  @@index([conversationId], map: "Message_conversationId_idx")
}

model prompttemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  prompt      String   @db.LongText
  tags        String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "PromptTemplate_userId_fkey")

  @@index([userId], map: "PromptTemplate_userId_idx")
}

model subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique(map: "Subscription_userId_key")
  stripeCustomerId       String?   @unique(map: "Subscription_stripeCustomerId_key")
  stripeSubscriptionId   String?   @unique(map: "Subscription_stripeSubscriptionId_key")
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
}

model user {
  id               String            @id @default(cuid())
  email            String            @unique(map: "User_email_key")
  name             String?
  clerkId          String            @unique(map: "User_clerkId_key")
  imageUrl         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  plan             String            @default("FREE")
  stripeCustomerId String?           @unique(map: "User_stripeCustomerId_key")
  credits          Int               @default(1000)
  conversation     conversation[]
  document         document[]
  prompttemplate   prompttemplate[]
  workspacemember  workspacemember[]
}

model workspace {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique(map: "Workspace_slug_key")
  imageUrl        String?
  inviteCode      String            @unique(map: "Workspace_inviteCode_key")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  conversation    conversation[]
  knowledgebase   knowledgebase?
  workspacemember workspacemember[]
}

model workspacemember {
  id          String    @id @default(cuid())
  role        String    @default("MEMBER")
  userId      String
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        user      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "WorkspaceMember_userId_fkey")
  workspace   workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, map: "WorkspaceMember_workspaceId_fkey")

  @@unique([userId, workspaceId], map: "WorkspaceMember_userId_workspaceId_key")
  @@index([workspaceId], map: "WorkspaceMember_workspaceId_fkey")
}
